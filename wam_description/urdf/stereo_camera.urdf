<?xml version="1.0" ?>
<robot name="aaa" xmlns:xacro="http://wiki.ros.org/xacro">

  <link name ="base_link"/>

  <xacro:include filename="$(find wam_description
			   )/urdf/stereo_camera.urdf.xacro" />

  <xacro:stereo_camera prefix="left_lbr_gripper_" parent_link="base_link">
    <origin xyz="0 0 0" rpy="0 -1.5706 0"/>
  </xacro:stereo_camera>

</robot>
