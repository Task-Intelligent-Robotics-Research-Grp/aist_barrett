	    hardware_interface/PositionJointInterface
	  </hardwareInterface>
	</joint>
	<actuator name="q1_motor">
	  <hardwareInterface>
	    hardware_interface/PositionJointInterface
	  </hardwareInterface>
	  <mechanicalReduction>
	    1
	  </mechanicalReduction>
	</actuator>
      </transmission>
